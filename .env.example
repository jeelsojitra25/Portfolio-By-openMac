# Server
NODE_ENV=development
PORT=3001

# PostgreSQL (Supabase or local)
DATABASE_URL=postgres://user:password@localhost:5432/qwen25
POSTGRES_USER=qwen
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate RS256 key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Admin account (seed script)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=SuperSecurePassword123!

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# Rate limiter salt (random string)
IP_SALT=change_me_to_a_random_string

# Contact form (optional: nodemailer SMTP)
CONTACT_EMAIL=contact@yourdomain.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=smtp_password
